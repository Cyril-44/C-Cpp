CompileFlags:
  Add: [
    "-std=c++20",
    "-I/usr/lib/llvm-18/include",
    "-I/home/cyril/C-Cpp",
    "-DDEBUG",
    "-D_GNU_SOURCE",
    "-Wall",
    "-Wextra",
    "-stdlib=libstdc++",
    "-fexperimental-new-constant-interpreter"
  ]
  Remove: [
    "-stdlib=libc++"
  ]
  Compiler: /usr/bin/g++-12

Diagnostics:
  Suppress: ["unknown-warning-option"]

