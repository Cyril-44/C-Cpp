    BADGES[i].test_fn = (lambda b=BADGES[i]: (lambda x: _badge_test(b, x)))()

from .utils import is_prime, MAXN


@dataclass
class Badge:
    name: str
    desc: str
    poss: int
    testtype: int
    test_fn: Callable[[int], bool] = (lambda x: False)

    def test(self, x: int) -> bool:
        # call the per-badge test function (assigned below)
        return bool(self.test_fn(x))


# build BADGES list where index matches original (1-based)
BADGES = [None]
for d in BADGES_DATA:
    # create Badge with placeholder test_fn; actual function assigned after _badge_test definition
    BADGES.append(Badge(d['name'], d.get('desc',''), d.get('poss',0), d.get('testtype', TYPE_SPECIAL)))

MAX_BADGE_INDEX = len(BADGES)-1


# Badge test implementation (port of original have_badge logic but using Badge instances)
def _badge_test(badge: Badge, x: int) -> bool:
    t = badge.testtype
    name = badge.name
    # build 9-digit array a[1..9]
    s9 = str(x).rjust(9, '0')
    a = [0]*10
    for i,ch in enumerate(s9, start=1):
        a[i] = int(ch)

    if t == TYPE_SPECIAL:
        if name == 'Prime':
            return is_prime(x)
        if name == 'Second Power':
            r = int(math.isqrt(x))
            return r*r == x
        if name == 'Third Power':
            r = int(round(x ** (1/3)))
            return r*r*r == x
        if name == 'Fourth Power':
            r = int(round(x ** 0.25))
            return r**4 == x
        if name == 'High Power':
            for base in range(2, 101):
                p = base**5
                while p <= MAXN:
                    if p == x:
                        return True
                    p *= base
            return False
        if name in ('Hopscotch', 'Hyper Hopscotch', 'Ultra Hopscotch'):
            if name == 'Hopscotch':
                for i in range(1,6):
                    if a[i] == a[i+2] and a[i+2] == a[i+4]:
                        return True
                return False
            if name == 'Hyper Hopscotch':
                for i in range(1,4):
                    if a[i] == a[i+2] == a[i+4] == a[i+6]:
                        return True
                return False
            if name == 'Ultra Hopscotch':
                return a[1]==a[3]==a[5]==a[7]==a[9]
        if name in ('Neutrality', 'Almost Sorted'):
            cnt1 = cnt2 = 0
            for i in range(1,9):
                for j in range(i+1,10):
                    if a[i] > a[j]:
                        cnt1 +=1
                    if a[i] < a[j]:
                        cnt2 +=1
            if name == 'Neutrality':
                return cnt1 == cnt2
            return cnt1 == 1 or cnt2 == 1
        if name == 'Zipper':
            return a[1]==a[3]==a[5]==a[7]==a[9] and a[2]==a[4]==a[6]==a[8]
        if name == 'Echo Form':
            for i in range(1,5):
                if a[i]==a[i+2]==a[i+4] and a[i+1]==a[i+3]==a[i+5]:
                    return True
            return False
        if name == 'Echo Form+':
            for i in range(1,3):
                if a[i]==a[i+2]==a[i+4]==a[i+6] and a[i+1]==a[i+3]==a[i+5]==a[i+7]:
                    return True
            return False
        if name == 'Echo Form Echo Form':
            return a[1]==a[4]==a[7] and a[2]==a[5]==a[8] and a[3]==a[6]==a[9]
        feather_names = {
            'Beginner Feather': 25, 'Beginner Heavy': 50,
            'Intermediate Feather': 20, 'Intermediate Heavy': 55,
            'Advanced Feather': 15, 'Advanced Heavy': 60,
            'Expert Feather': 10, 'Expert Heavy': 65,
            'Grandmaster Feather': 5, 'Grandmaster Heavy': 70
        }
        if name in feather_names:
            s = sum(a[1:10])
            thresh = feather_names[name]
            if 'Feather' in name:
                return s <= thresh
            else:
                return s >= thresh
        if name == 'Harshed Number':
            s = sum(a[1:10])
            return s > 0 and x % s == 0
        if name.startswith('Mini Palindrome'):
            k = int(name.split()[-1])
            for i in range(1, 10-k+1):
                ok = True
                for j in range(k//2):
                    if a[i+j] != a[i+k-1-j]:
                        ok = False
                        break
                if ok:
                    return True
            return False
        if name == 'Mini Echo':
            for i in range(1,7):
                if a[i]==a[i+2] and a[i+1]==a[i+3]:
                    return True
            return False
        if name == 'Medium Echo':
            for i in range(1,5):
                if a[i]==a[i+3] and a[i+1]==a[i+4] and a[i+2]==a[i+5]:
                    return True
            return False
        if name == 'Major Echo':
            for i in range(1,3):
                if a[i]==a[i+4] and a[i+1]==a[i+5] and a[i+2]==a[i+6] and a[i+3]==a[i+7]:
                    return True
            return False
        if name == 'Wide':
            return (max(a[1:10]) - min(a[1:10])) == 9
        if name == 'Slim':
            return (max(a[1:10]) - min(a[1:10])) <= 3
        if name == 'Palindrome':
            return a[1]==a[9] and a[2]==a[8] and a[3]==a[7] and a[4]==a[6]

    if t == TYPE_DIVIDE:
        import re
        desc = badge.desc if hasattr(badge,'desc') else ''
        m = re.search(r"Divisible by\s*(\d+)", desc)
        if m:
            d = int(m.group(1))
            return x % d == 0
        if name == 'Clean Ten':
            return x % 10 == 0
        if name == 'Clean Hundred':
            return x % 100 == 0
        if name == 'Clean Thousand':
            return x % 1000 == 0
        if name == 'Clean Ten Thousand':
            return x % 10000 == 0
        if name == 'Clean Hundred Thousand':
            return x % 100000 == 0
        if name == 'Clean Million':
            return x % 1000000 == 0
        if name == 'Clean Ten Million':
            return x % 10000000 == 0
        if name == 'Clean Hundred Million':
            return x % 100000000 == 0
        if name == 'Binary Clean':
            return x % 1024 == 0
        if name == 'Double Binary Clean':
            return x % 1048576 == 0
        return False

    if t == TYPE_CONTAIN:
        import re
        m = re.search(r"(\d+)", badge.desc if hasattr(badge,'desc') else '')
        if m:
            pat = m.group(1)
            return pat in s9
        return False

    if t == TYPE_NEEDAB:
        b = [0]*10
        for i in range(1,10):
            b[a[i]] += 1
        import re
        m = re.search(r"Contains exactly 1 \"?(\d)\"?", badge.desc if hasattr(badge,'desc') else '')
        if m:
            d = int(m.group(1))
            return b[d] == 1
        if name == 'Abyss':
            return b[0] == 0
        if name == 'Binary Soul':
            return b[0] + b[1] == 9
        if name == 'Low Ball':
            return sum(b[i] for i in range(0,5)) == 9
        if name == 'High Roller':
            return sum(b[i] for i in range(5,10)) == 8
        if name == 'Divisible by 3':
            return b[0] + b[3] + b[6] + b[9] == 9
        cnt = sum(1 for i in range(10) if b[i] > 0)
        maxx = max(b)
        if name == 'Skipping':
            for i in range(0,9):
                if b[i] and b[i+1]:
                    return False
            return True
        if name == 'Consecutive Pairs':
            for i in range(0,8):
                if b[i] >=2 and b[i+1] >=2 and b[i+2] >=2:
                    return True
            return False
        if name == 'Airplane':
            for i in range(0,9):
                if i+1<=9 and b[i] >=3 and b[min(i+1,9)] >=3:
                    return True
            return False
        if name == 'Triple Airplane':
            for i in range(0,8):
                if b[i]>=3 and b[i+1]>=3 and b[i+2]>=3:
                    return True
            return False
        if name == 'Consecutive Pairs+':
            for i in range(0,7):
                if b[i]>=2 and b[i+1]>=2 and b[i+2]>=2 and b[i+3]>=2:
                    return True
            return False
        if name.startswith('Digit Complex'):
            need = int(name.split()[-1])
            return cnt == need
        if name.startswith('Repeat'):
            nrep = int(name.split()[-1])
            return maxx >= nrep
        if name == 'Odd Todd':
            return sum(b[i] for i in [0,2,4,6,8]) == 0
        if name == 'Even Steven':
            return sum(b[i] for i in [1,3,5,7,9]) == 0
        if name == 'Almost Balanced':
            evencnt = sum(b[i] for i in [0,2,4,6,8])
            return evencnt == 4 or evencnt == 5
        buc = [0]*10
        for i in range(10):
            buc[b[i]] += 1
        c = []
        for val in range(9,-1,-1):
            c.extend([val]*buc[val])
        freq_sorted = sorted([cnt for cnt in b if cnt>0], reverse=True)
        if name == 'Two Pair':
            return len(freq_sorted) >= 2 and freq_sorted[0] >=2 and freq_sorted[1] >=2
        if name == 'Three Pair':
            return len(freq_sorted) >= 3 and freq_sorted[0] >=2 and freq_sorted[1] >=2 and freq_sorted[2] >=2
        if name == 'Four Pair':
            return len(freq_sorted) >= 4 and all(freq_sorted[i] >=2 for i in range(4))
        if name == 'Full House':
            return len(freq_sorted) >=2 and freq_sorted[0] >=3 and freq_sorted[1] >=2
        if name == 'Two Triplet':
            return len(freq_sorted) >=2 and freq_sorted[0] >=3 and freq_sorted[1] >=3
        if name == 'Three Triplet':
            return len(freq_sorted) >=3 and freq_sorted[0] >=3 and freq_sorted[1] >=3 and freq_sorted[2] >=3
        return False

    if t == TYPE_DIFFER:
        diff = [0]*9
        for i in range(1,9):
            diff[i] = a[i+1] - a[i]
        if name == 'Even Spacing (Absolute)':
            for i in range(1,8):
                if diff[i]*diff[i] != diff[i+1]*diff[i+1]:
                    return False
            return True
        if name == 'Turtle':
            for i in range(1,9):
                if diff[i] > 1 or diff[i] < -1:
                    return False
            return True
        if name == 'German Whisper':
            for i in range(1,9):
                if diff[i] > -5 and diff[i] < 5:
                    return False
            return True
        if name == 'Hills':
            for i in range(1,8):
                if diff[i]*diff[i+1] >= 0:
                    return False
            return True
        if name == 'Dunes':
            for i in range(1,8):
                if diff[i]*diff[i+1] > 0:
                    return False
            return True
        if name in ('Mountain','Mesa','Valley','Canyon'):
            atl = 1
            if name in ('Mesa','Canyon'):
                atl = 0
            mtp = 1
            if name in ('Valley','Canyon'):
                mtp = -1
            xl = xr = 0
            for i in range(1,9):
                if diff[i]*mtp >= atl:
                    xl += 1
                else:
                    break
            for i in range(8,0,-1):
                if diff[i]*mtp <= -atl:
                    xr += 1
                else:
                    break
            return xl + xr >= 8
        if name.startswith('Consecutive') or name.startswith('Contiguous'):
            ava1, ava2 = 1, -1
            if name.startswith('Contiguous'):
                ava1 = ava2 = 0
            cur = 0
            maxx = 0
            for j in range(1,9):
                cur += 1
                if diff[j] != ava1 and diff[j] != ava2:
                    cur = 0
                if j == 8 or diff[j] != diff[j+1]:
                    maxx = max(maxx, cur)
                    cur = 0
            key = name
            if key in ('Consecutive 3','Contiguous 3'):
                return maxx >= 2
            if key in ('Consecutive 2','Contiguous 2'):
                return maxx >= 1
            if key in ('Consecutive 4','Contiguous 4'):
                return maxx >= 3
            if key in ('Consecutive 5','Contiguous 5'):
                return maxx >= 4
            if key in ('Consecutive 6','Contiguous 6'):
                return maxx >= 5
            if key in ('Consecutive 7','Contiguous 7'):
                return maxx >= 6
            if key in ('Consecutive 8','Contiguous 8'):
                return maxx >= 7
            if key == 'Consecutive 9':
                return maxx >= 8
        if name == 'Alternator':
            for i in range(1,9):
                if (diff[i] + 20) % 2 == 0:
                    return False
            return True
        if name in ('Two Contiguous Pair','Three Contiguous Pair','Four Contiguous Pair'):
            cnt = sum(1 for i in range(1,9) if diff[i] == 0)
            if name == 'Two Contiguous Pair':
                return cnt >= 2
            if name == 'Three Contiguous Pair':
                return cnt >= 3
            if name == 'Four Contiguous Pair':
                return cnt >= 4
        if name == 'Steps':
            for i in range(1,9):
                if diff[i] < 0:
                    return False
            return True
        if name == 'Slopes':
            for i in range(1,9):
                if diff[i] > 0:
                    return False
            return True
        return False


# --- Build per-badge test functions and attach to BADGES and BADGES_DATA ---
# Define helpers to build the 9-digit array and common checks

def buildA(x: int):
    s9 = str(x).rjust(9, '0')
    a = [0]*10
    for i,ch in enumerate(s9, start=1):
        a[i] = int(ch)
    return s9, a


def digitCounts(a):
    b = [0]*10
    for i in range(1,10):
        b[a[i]] += 1
    return b


def freqSorted(b):
    return sorted([cnt for cnt in b if cnt>0], reverse=True)


# small factories
def containsFactory(pat: str):
    def f(x: int) -> bool:
        s9, a = buildA(x)
        return pat in s9
    return f


def divisibleFactory(d: int):
    def f(x: int) -> bool:
        return (x % d) == 0
    return f


# explicit per-badge assignments (no fallback to _badge_test)

# --- Hand-written sample tests (Prime, Repeat 9, Clean Million) ---

def test_prime(x:int) -> bool:
    # primality test using existing is_prime
    return is_prime(x)


def test_repeat_9(x:int) -> bool:
    # all nine digits equal
    s9,a = buildA(x)
    # if a digit appears 9 times -> max count == 9
    b = digitCounts(a)
    return max(b) >= 9


def test_clean_million(x:int) -> bool:
    # ends with 6 zeros -> divisible by 1_000_000
    return (x % 1000000) == 0

for idx, badge in enumerate(BADGES[1:], start=1):
    name = badge.name
    # SPECIAL types
    if name == 'Prime':
        badge.test_fn = is_prime
        BADGES_DATA[idx-1]['test'] = badge.test_fn
        continue
    if name == 'Second Power':
        badge.test_fn = lambda x: (int(math.isqrt(x)) ** 2) == x
        BADGES_DATA[idx-1]['test'] = badge.test_fn
        continue
    if name == 'Third Power':
        badge.test_fn = lambda x: (int(round(x ** (1/3))) ** 3) == x
        BADGES_DATA[idx-1]['test'] = badge.test_fn
        continue
    if name == 'Fourth Power':
        badge.test_fn = lambda x: (int(round(x ** 0.25)) ** 4) == x
        BADGES_DATA[idx-1]['test'] = badge.test_fn
        continue
    if name == 'High Power':
        def high_power(x:int):
            for base in range(2, 101):
                p = base**5
                while p <= MAXN:
                    if p == x:
                        return True
                    p *= base
            return False
        badge.test_fn = high_power
        BADGES_DATA[idx-1]['test'] = badge.test_fn
        continue
    if name in ('Hopscotch', 'Hyper Hopscotch', 'Ultra Hopscotch'):
        if name == 'Hopscotch':
            badge.test_fn = lambda x: any(
                (buildA(x)[1][i] == buildA(x)[1][i+2] == buildA(x)[1][i+4])
                for i in range(1,6)
            )
        elif name == 'Hyper Hopscotch':
            badge.test_fn = lambda x: any(
                (buildA(x)[1][i] == buildA(x)[1][i+2] == buildA(x)[1][i+4] == buildA(x)[1][i+6])
                for i in range(1,4)
            )
        else:
            badge.test_fn = lambda x: (buildA(x)[1][1] == buildA(x)[1][3] == buildA(x)[1][5] == buildA(x)[1][7] == buildA(x)[1][9])
        BADGES_DATA[idx-1]['test'] = badge.test_fn
        continue
    if name in ('Neutrality', 'Almost Sorted'):
        def neutrality_fn(x:int, want_neutral=False):
            s9,a = buildA(x)
            cnt1=cnt2=0
            for i in range(1,9):
                for j in range(i+1,10):
                    if a[i] > a[j]: cnt1 += 1
                    if a[i] < a[j]: cnt2 += 1
            if want_neutral:
                return cnt1 == cnt2
            return cnt1 == 1 or cnt2 == 1
        if name == 'Neutrality':
            badge.test_fn = lambda x: neutrality_fn(x, want_neutral=True)
        else:
            badge.test_fn = lambda x: neutrality_fn(x, want_neutral=False)
        BADGES_DATA[idx-1]['test'] = badge.test_fn
        continue
    if name == 'Zipper':
        badge.test_fn = lambda x: (lambda s9,a: (a[1]==a[3]==a[5]==a[7]==a[9] and a[2]==a[4]==a[6]==a[8]))(buildA(x)[0], buildA(x)[1])
        BADGES_DATA[idx-1]['test'] = badge.test_fn
        continue
    if name == 'Echo Form':
        def echo_form(x:int):
            s9,a = buildA(x)
            for i in range(1,5):
                if a[i]==a[i+2]==a[i+4] and a[i+1]==a[i+3]==a[i+5]:
                    return True
            return False
        badge.test_fn = echo_form
        BADGES_DATA[idx-1]['test'] = badge.test_fn
        continue
    if name == 'Echo Form+':
        def echo_form_plus(x:int):
            s9,a = buildA(x)
            for i in range(1,3):
                if a[i]==a[i+2]==a[i+4]==a[i+6] and a[i+1]==a[i+3]==a[i+5]==a[i+7]:
                    return True
            return False
        badge.test_fn = echo_form_plus
        BADGES_DATA[idx-1]['test'] = badge.test_fn
        continue
    if name == 'Echo Form Echo Form':
        badge.test_fn = lambda x: (lambda s9,a: (a[1]==a[4]==a[7] and a[2]==a[5]==a[8] and a[3]==a[6]==a[9]))(buildA(x)[0], buildA(x)[1])
        BADGES_DATA[idx-1]['test'] = badge.test_fn
        continue
    # Feather / Heavy series
    feather_names = {
        'Beginner Feather': (25, True), 'Beginner Heavy': (50, False),
        'Intermediate Feather': (20, True), 'Intermediate Heavy': (55, False),
        'Advanced Feather': (15, True), 'Advanced Heavy': (60, False),
        'Expert Feather': (10, True), 'Expert Heavy': (65, False),
        'Grandmaster Feather': (5, True), 'Grandmaster Heavy': (70, False)
    }
    if name in feather_names:
        thresh, is_feather = feather_names[name]
        if is_feather:
            badge.test_fn = lambda x, t=thresh: sum(buildA(x)[1][1:10]) <= t
        else:
            badge.test_fn = lambda x, t=thresh: sum(buildA(x)[1][1:10]) >= t
        BADGES_DATA[idx-1]['test'] = badge.test_fn
        continue
    if name == 'Harshed Number':
        badge.test_fn = lambda x: (lambda s9,a: (sum(a[1:10])>0 and x % sum(a[1:10]) == 0))(*buildA(x))
        BADGES_DATA[idx-1]['test'] = badge.test_fn
        continue
    if name.startswith('Mini Palindrome'):
        k = int(name.split()[-1])
        def make_minipal(k):
            def f(x:int):
                s9,a = buildA(x)
                for i in range(1, 10-k+1):
                    ok = True
                    for j in range(k//2):
                        if a[i+j] != a[i+k-1-j]:
                            ok = False
                            break
                    if ok:
                        return True
                return False
            return f
        badge.test_fn = make_minipal(k)
        BADGES_DATA[idx-1]['test'] = badge.test_fn
        continue
    if name == 'Mini Echo':
        def mini_echo(x:int):
            s9,a = buildA(x)
            for i in range(1,7):
                if a[i]==a[i+2] and a[i+1]==a[i+3]:
                    return True
            return False
        badge.test_fn = mini_echo
        BADGES_DATA[idx-1]['test'] = badge.test_fn
        continue
    if name == 'Medium Echo':
        def medium_echo(x:int):
            s9,a = buildA(x)
            for i in range(1,5):
                if a[i]==a[i+3] and a[i+1]==a[i+4] and a[i+2]==a[i+5]:
                    return True
            return False
        badge.test_fn = medium_echo
        BADGES_DATA[idx-1]['test'] = badge.test_fn
        continue
    if name == 'Major Echo':
        def major_echo(x:int):
            s9,a = buildA(x)
            for i in range(1,3):
                if a[i]==a[i+4] and a[i+1]==a[i+5] and a[i+2]==a[i+6] and a[i+3]==a[i+7]:
                    return True
            return False
        badge.test_fn = major_echo
        BADGES_DATA[idx-1]['test'] = badge.test_fn
        continue
    if name == 'Wide':
        badge.test_fn = lambda x: (lambda s9,a: (max(a[1:10]) - min(a[1:10]) == 9))(*buildA(x))
        BADGES_DATA[idx-1]['test'] = badge.test_fn
        continue
    if name == 'Slim':
        badge.test_fn = lambda x: (lambda s9,a: (max(a[1:10]) - min(a[1:10]) <= 3))(*buildA(x))
        BADGES_DATA[idx-1]['test'] = badge.test_fn
        continue
    if name == 'Palindrome':
        badge.test_fn = lambda x: (lambda s9,a: (a[1]==a[9] and a[2]==a[8] and a[3]==a[7] and a[4]==a[6]))(*buildA(x))
        BADGES_DATA[idx-1]['test'] = badge.test_fn
        continue
    # DIVIDE types explicit mapping
    divide_map = {
        'High Man':2, 'Basketball Champion':3, 'ICU':5, 'Monitor':7, 'Li Yin Yang':11,
        'Duck Neck':13, 'Old Hill':15, 'Negro':17, 'Big Plate Chicken':19, 'Chicken Dust':23,
        'Kevin (Divisible)':27, 'Plus Seven':29, 'Blue Archive':31, 'Iron Ke':37, 'Chicken Neck':41,
        'Mason Xu':43, 'Red Chicken':47, 'ZnSO4':49,
    }
    if name in divide_map:
        d = divide_map[name]
        badge.test_fn = divisibleFactory(d)
        BADGES_DATA[idx-1]['test'] = badge.test_fn
        continue
    clean_zeros = {
        'Clean Ten':10,'Clean Hundred':100,'Clean Thousand':1000,'Clean Ten Thousand':10000,
        'Clean Hundred Thousand':100000,'Clean Million':1000000,'Clean Ten Million':10000000,'Clean Hundred Million':100000000
    }
    if name in clean_zeros:
        badge.test_fn = divisibleFactory(clean_zeros[name])
        BADGES_DATA[idx-1]['test'] = badge.test_fn
        continue
    if name == 'Binary Clean':
        badge.test_fn = divisibleFactory(1024)
        BADGES_DATA[idx-1]['test'] = badge.test_fn
        continue
    if name == 'Double Binary Clean':
        badge.test_fn = divisibleFactory(1048576)
        BADGES_DATA[idx-1]['test'] = badge.test_fn
        continue
    # CONTAIN explicit list
    contain_map = {
        'Homo 3':'114','Homo 4':'1145','Homo 5':'11451','Full Homo':'114514',
        'Half Homo B-Side':'1919','Homo B-Side':'1919810','Kevin':'27','O Kevin':'15',
        'Consecutive 3':'3','Consecutive 2':'2','Consecutive 4':'4','Consecutive 5':'5','Consecutive 6':'6',
        'Consecutive 7':'7','Consecutive 8':'8','Consecutive 9':'9','Contiguous 2':'2','Contiguous 3':'3',
        'Contiguous 4':'4','Contiguous 5':'5','Contiguous 6':'6','Contiguous 7':'7','Contiguous 8':'8',
        'Six Seven':'67','Six Six Six':'666','Calender':'365','Emergency':'911','Not Found':'404','Slience in Sea':'543'
    }
    if name in contain_map:
        badge.test_fn = containsFactory(contain_map[name])
        BADGES_DATA[idx-1]['test'] = badge.test_fn
        continue
    # NEEDAB types and other specific ones
    if name == 'Even Steven':
        badge.test_fn = lambda x: sum(digitCounts(buildA(x)[1])[i] for i in [1,3,5,7,9]) == 0
        BADGES_DATA[idx-1]['test'] = badge.test_fn
        continue
    if name == 'Odd Todd':
        badge.test_fn = lambda x: sum(digitCounts(buildA(x)[1])[i] for i in [0,2,4,6,8]) == 0
        BADGES_DATA[idx-1]['test'] = badge.test_fn
        continue
    if name == 'Abyss':
        badge.test_fn = lambda x: digitCounts(buildA(x)[1])[0] == 0
        BADGES_DATA[idx-1]['test'] = badge.test_fn
        continue
    if name == 'Void':
        def void_fn(x:int):
            return digitCounts(buildA(x)[1])[0] == 1
        badge.test_fn = void_fn
        BADGES_DATA[idx-1]['test'] = badge.test_fn
        continue
    if name.startswith('Digit Complex'):
        need = int(name.split()[-1])
        badge.test_fn = lambda x, n=need: sum(1 for cnt in digitCounts(buildA(x)[1]) if cnt>0) == n
        BADGES_DATA[idx-1]['test'] = badge.test_fn
        continue
    if name.startswith('Repeat'):
        nrep = int(name.split()[-1])
        badge.test_fn = lambda x, r=nrep: max(digitCounts(buildA(x)[1])) >= r
        BADGES_DATA[idx-1]['test'] = badge.test_fn
        continue
    if name == 'Almost Balanced':
        badge.test_fn = lambda x: (lambda b: (sum(b[i] for i in [0,2,4,6,8]) == 4 or sum(b[i] for i in [0,2,4,6,8]) == 5))(digitCounts(buildA(x)[1]))
        BADGES_DATA[idx-1]['test'] = badge.test_fn
        continue
    if name == 'Skipping':
        def skipping_fn(x:int):
            b = digitCounts(buildA(x)[1])
            for i in range(0,9):
                if b[i] and b[i+1]:
                    return False
            return True
        badge.test_fn = skipping_fn
        BADGES_DATA[idx-1]['test'] = badge.test_fn
        continue
    # Pairs / triplets / full house etc.
    if name == 'Two Pair':
        badge.test_fn = lambda x: (lambda b: (lambda f: len(f)>=2 and f[0]>=2 and f[1]>=2)(sorted([cnt for cnt in b if cnt>0], reverse=True)))(digitCounts(buildA(x)[1]))
        BADGES_DATA[idx-1]['test'] = badge.test_fn
        continue
    if name == 'Three Pair':
        badge.test_fn = lambda x: (lambda b: (lambda f: len(f)>=3 and f[0]>=2 and f[1]>=2 and f[2]>=2)(sorted([cnt for cnt in b if cnt>0], reverse=True)))(digitCounts(buildA(x)[1]))
        BADGES_DATA[idx-1]['test'] = badge.test_fn
        continue
    if name == 'Four Pair':
        badge.test_fn = lambda x: (lambda f: len(f)>=4 and all(f[i]>=2 for i in range(4))) (sorted([cnt for cnt in digitCounts(buildA(x)[1]) if cnt>0], reverse=True))
        BADGES_DATA[idx-1]['test'] = badge.test_fn
        continue
    if name == 'Full House':
        badge.test_fn = lambda x: (lambda f: len(f)>=2 and f[0]>=3 and f[1]>=2)(sorted([cnt for cnt in digitCounts(buildA(x)[1]) if cnt>0], reverse=True))
        BADGES_DATA[idx-1]['test'] = badge.test_fn
        continue
    if name == 'Two Triplet':
        badge.test_fn = lambda x: (lambda f: len(f)>=2 and f[0]>=3 and f[1]>=3)(sorted([cnt for cnt in digitCounts(buildA(x)[1]) if cnt>0], reverse=True))
        BADGES_DATA[idx-1]['test'] = badge.test_fn
        continue
    if name == 'Three Triplet':
        badge.test_fn = lambda x: (lambda f: len(f)>=3 and f[0]>=3 and f[1]>=3 and f[2]>=3)(sorted([cnt for cnt in digitCounts(buildA(x)[1]) if cnt>0], reverse=True))
        BADGES_DATA[idx-1]['test'] = badge.test_fn
        continue
    # DIFFER type complex cases (Steps, Slopes, Mountain, etc.)
    if name in ('Steps','Slopes','Mountain','Mesa','Valley','Canyon','Hills','Dunes'):
        def make_diff_fn(key):
            def f(x:int):
                s9,a = buildA(x)
                diff = [0]*9
                for i in range(1,9):
                    diff[i] = a[i+1] - a[i]
                if key == 'Steps':
                    for i in range(1,9):
                        if diff[i] < 0: return False
                    return True
                if key == 'Slopes':
                    for i in range(1,9):
                        if diff[i] > 0: return False
                    return True
                if key == 'Hills':
                    for i in range(1,8):
                        if diff[i]*diff[i+1] >= 0: return False
                    return True
                if key == 'Dunes':
                    for i in range(1,8):
                        if diff[i]*diff[i+1] > 0: return False
                    return True
                if key in ('Mountain','Mesa','Valley','Canyon'):
                    atl = 1
                    if key in ('Mesa','Canyon'):
                        atl = 0
                    mtp = 1
                    if key in ('Valley','Canyon'):
                        mtp = -1
                    xl = xr = 0
                    for i in range(1,9):
                        if diff[i]*mtp >= atl:
                            xl += 1
                        else:
                            break
                    for i in range(8,0,-1):
                        if diff[i]*mtp <= -atl:
                            xr += 1
                        else:
                            break
                    return xl + xr >= 8
                return False
            return f
        badge.test_fn = make_diff_fn(name)
        BADGES_DATA[idx-1]['test'] = badge.test_fn
        continue
    # Contiguous / Consecutive / Alternator / Two Contiguous Pair etc.
    if name.startswith('Consecutive') or name.startswith('Contiguous') or name in ('Alternator','Two Contiguous Pair','Three Contiguous Pair','Four Contiguous Pair') or name.startswith('Consecutive Pairs') or name in ('Two Contiguous Pair','Three Contiguous Pair','Four Contiguous Pair'):
        def make_cont_fn(key):
            def f(x:int):
                s9,a = buildA(x)
                diff = [0]*9
                for i in range(1,9):
                    diff[i] = a[i+1] - a[i]
                ava1, ava2 = 1, -1
                if key.startswith('Contiguous'):
                    ava1 = ava2 = 0
                cur = 0
                maxx = 0
                for j in range(1,9):
                    cur += 1
                    if diff[j] != ava1 and diff[j] != ava2:
                        cur = 0
                    if j == 8 or diff[j] != diff[j+1]:
                        maxx = max(maxx, cur)
                        cur = 0
                if key in ('Consecutive 3','Contiguous 3'):
                    return maxx >= 2
                if key in ('Consecutive 2','Contiguous 2'):
                    return maxx >= 1
                if key in ('Consecutive 4','Contiguous 4'):
                    return maxx >= 3
                if key in ('Consecutive 5','Contiguous 5'):
                    return maxx >= 4
                if key in ('Consecutive 6','Contiguous 6'):
                    return maxx >= 5
                if key in ('Consecutive 7','Contiguous 7'):
                    return maxx >= 6
                if key in ('Consecutive 8','Contiguous 8'):
                    return maxx >= 7
                if key == 'Consecutive 9':
                    return maxx >= 8
                if key == 'Alternator':
                    for i in range(1,9):
                        if (diff[i] + 20) % 2 == 0:
                            return False
                    return True
                if key == 'Two Contiguous Pair':
                    cnt = sum(1 for i in range(1,9) if diff[i] == 0)
                    return cnt >= 2
                if key == 'Three Contiguous Pair':
                    cnt = sum(1 for i in range(1,9) if diff[i] == 0)
                    return cnt >= 3
                if key == 'Four Contiguous Pair':
                    cnt = sum(1 for i in range(1,9) if diff[i] == 0)
                    return cnt >= 4
                return False
            return f
        badge.test_fn = make_cont_fn(name)
        BADGES_DATA[idx-1]['test'] = badge.test_fn
        continue
    # Zipper handled earlier, Two Pair series handled earlier, Steps etc handled
    # Additional explicit cases not covered above
    if name == 'Binary Soul':
        badge.test_fn = lambda x: digitCounts(buildA(x)[1])[0] + digitCounts(buildA(x)[1])[1] == 9
        BADGES_DATA[idx-1]['test'] = badge.test_fn
        continue
    if name == 'Low Ball':
        badge.test_fn = lambda x: sum(digitCounts(buildA(x)[1])[i] for i in range(0,5)) == 9
        BADGES_DATA[idx-1]['test'] = badge.test_fn
        continue
    if name == 'High Roller':
        badge.test_fn = lambda x: sum(digitCounts(buildA(x)[1])[i] for i in range(5,10)) == 8
        BADGES_DATA[idx-1]['test'] = badge.test_fn
        continue
    if name == 'Divisible by 3':
        badge.test_fn = lambda x: (digitCounts(buildA(x)[1])[0] + digitCounts(buildA(x)[1])[3] + digitCounts(buildA(x)[1])[6] + digitCounts(buildA(x)[1])[9]) == 9
        BADGES_DATA[idx-1]['test'] = badge.test_fn
        continue
    # Elements: Hydrogen..Fluorine -> contains exactly one specific digit
    element_map = {
        'Hydrogen':1,'Helium':2,'Lithium':3,'Beryllium':4,'Boron':5,'Carbon':6,'Nitrogen':7,'Oxygen':8,'Fluorine':9
    }
    if name in element_map:
        d = element_map[name]
        badge.test_fn = lambda x, dd=d: digitCounts(buildA(x)[1])[dd] == 1
        BADGES_DATA[idx-1]['test'] = badge.test_fn
        continue
    if name == 'Consecutive Pairs':
        badge.test_fn = lambda x: any(digitCounts(buildA(x)[1])[i] >=2 and digitCounts(buildA(x)[1])[i+1] >=2 and digitCounts(buildA(x)[1])[i+2] >=2 for i in range(0,8))
        BADGES_DATA[idx-1]['test'] = badge.test_fn
        continue
    if name == 'Airplane':
        def airplane_fn(x:int):
            b = digitCounts(buildA(x)[1])
            for i in range(0,9):
                if i+1<=9 and b[i] >=3 and b[min(i+1,9)] >=3:
                    return True
            return False
        badge.test_fn = airplane_fn
        BADGES_DATA[idx-1]['test'] = badge.test_fn
        continue
    if name == 'Triple Airplane':
        badge.test_fn = lambda x: any(digitCounts(buildA(x)[1])[i] >=3 and digitCounts(buildA(x)[1])[i+1] >=3 and digitCounts(buildA(x)[1])[i+2] >=3 for i in range(0,8))
        BADGES_DATA[idx-1]['test'] = badge.test_fn
        continue
    if name == 'Consecutive Pairs+':
        badge.test_fn = lambda x: any(digitCounts(buildA(x)[1])[i] >=2 and digitCounts(buildA(x)[1])[i+1] >=2 and digitCounts(buildA(x)[1])[i+2] >=2 and digitCounts(buildA(x)[1])[i+3] >=2 for i in range(0,7))
        BADGES_DATA[idx-1]['test'] = badge.test_fn
        continue
    # If still unmatched, set to explicit False to avoid calling _badge_test
    badge.test_fn = (lambda: (lambda x: False))()
    BADGES_DATA[idx-1]['test'] = badge.test_fn

# --- Override: hand-written explicit tests for first 20 badges (batch 1) ---
# factories used here (reuse helpers from above)

def digitComplexFactory(n:int):
    def f(x:int) -> bool:
        b = digitCounts(buildA(x)[1])
        return sum(1 for cnt in b if cnt>0) == n
    return f


def repeatFactory(r:int):
    def f(x:int) -> bool:
        b = digitCounts(buildA(x)[1])
        return max(b) >= r
    return f


# Assign explicit test functions for badges 1..20
try:
    BADGES[1].test_fn = divisibleFactory(10)  # Clean Ten
    BADGES[2].test_fn = digitComplexFactory(2)  # Digit Complex 2
    BADGES[3].test_fn = digitComplexFactory(3)
    BADGES[4].test_fn = digitComplexFactory(4)
    BADGES[5].test_fn = digitComplexFactory(5)
    BADGES[6].test_fn = digitComplexFactory(6)
    BADGES[7].test_fn = digitComplexFactory(7)
    BADGES[8].test_fn = digitComplexFactory(8)
    BADGES[9].test_fn = digitComplexFactory(9)
    BADGES[10].test_fn = repeatFactory(4)
    BADGES[11].test_fn = repeatFactory(5)
    BADGES[12].test_fn = repeatFactory(6)
    BADGES[13].test_fn = repeatFactory(7)
    BADGES[14].test_fn = repeatFactory(8)
    BADGES[15].test_fn = repeatFactory(9)
    BADGES[16].test_fn = is_prime
    BADGES[17].test_fn = divisibleFactory(2)
    BADGES[18].test_fn = divisibleFactory(3)
    BADGES[19].test_fn = divisibleFactory(5)
    BADGES[20].test_fn = divisibleFactory(7)
except Exception:
    # Defensive: if BADGES not fully built, skip assignments
    pass
